---
import contributorsData from '@/v2026/data/contributors-2026.json'
import ContributorsCard from '@/v2026/components/sections/contributors/ContributorsCard.astro'

type Network = {
  network_name: string
  username: string
  url: string
}

type Contributor = {
  name: string
  role: string
  level: 'gold' | 'silver' | 'bronze'
  networks: Network[]
}

const contributors = (contributorsData.contributors ?? []) as Contributor[]

const LEVEL_ORDER: Record<string, number> = {
  gold: 1,
  silver: 2,
  bronze: 3
};

const sortedContributors = [...contributors].sort((a, b) => {
  const levelA = LEVEL_ORDER[a.level.toLowerCase()] ?? 99;
  const levelB = LEVEL_ORDER[b.level.toLowerCase()] ?? 99;
  return levelA - levelB;
});

type AvatarAsset =
  | string
  | {
      src: string
    }

const avatarModules = (
  import.meta as ImportMeta & {
    glob: (
      pattern: string,
      options?: { eager?: boolean; import?: string }
    ) => Record<string, AvatarAsset>
  }
).glob('../../assets/contributors/*.webp', {
  eager: true,
  import: 'default',
}) as Record<string, AvatarAsset>

const avatarByName: Record<string, string> = Object.fromEntries(
  Object.entries(avatarModules).map(([filePath, assetUrl]) => {
    const fileName = filePath.split('/').pop() ?? ''
    const baseName = fileName.replace(/\.webp$/i, '').replace(/[-_](icon|avatar)$/i, '')
    const resolvedUrl = typeof assetUrl === 'string' ? assetUrl : assetUrl.src
    return [baseName.toLowerCase(), resolvedUrl]
  })
)

const normalizeKey = (value: string): string =>
  value
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .trim()

const getAvatar = (name: string): string | null => {
  const normalized = normalizeKey(name)
  const chunks = normalized.split(' ').filter(Boolean)
  const firstName = chunks[0] ?? ''
  const secondName = chunks[1] ?? ''

  return avatarByName[normalized] ?? avatarByName[firstName] ?? avatarByName[secondName] ?? null
}
---

<section id="contributors" class="contributors-section">
  <div class="contributors-shell">
    <header class="contributors-header">
      <p class="contributors-kicker">Contributors</p>
      <h2>Equipo 2026</h2>
      <p class="contributors-description">
        Personas que construyeron en esta edición de FLISoL con código, diseño y comunidad.
      </p>
    </header>

    <div class="contributors-grid">
      {
        sortedContributors.map((contributor) => (
          <ContributorsCard contributor={contributor} avatar={getAvatar(contributor.name)} />
        ))
      }
    </div>

    <div class="contributors-legend" aria-label="Significado de niveles de contribution">
      <p class="legend-title">Niveles de contribution</p>
      <ul class="legend-list">
        <li class="legend-item legend-gold">
          <span class="legend-swatch" aria-hidden="true"></span>
          <span><strong>Oro:</strong> Aportes clave con gran impacto en el proyecto.</span>
        </li>
        <li class="legend-item legend-silver">
          <span class="legend-swatch" aria-hidden="true"></span>
          <span><strong>Plata:</strong> Contribuciones constantes y mejoras relevantes.</span>
        </li>
        <li class="legend-item legend-bronze">
          <span class="legend-swatch" aria-hidden="true"></span>
          <span
            ><strong>Bronce:</strong> Aportes puntuales como botones, estilos o ajustes útiles.</span
          >
        </li>
      </ul>
    </div>
  </div>
</section>

<style>
  .contributors-section {
    padding: 4.8rem 0.8rem 5.4rem;
    background:
      linear-gradient(180deg, rgba(19, 8, 49, 0.95) 0%, rgba(16, 9, 43, 0.98) 100%),
      radial-gradient(circle at 10% 20%, rgba(66, 150, 202, 0.22), transparent 34%),
      radial-gradient(circle at 85% 5%, rgba(233, 186, 45, 0.13), transparent 30%);
    border-top: 4px solid #4296ca;
  }

  .contributors-shell {
    width: min(1460px, calc(100vw - 1.6rem));
    margin: 0 auto;
  }

  .contributors-header {
    color: #f9f8ff;
    margin-bottom: 1.5rem;
  }

  .contributors-kicker {
    font-size: 0.72rem;
    color: #e9ba2d;
    margin-bottom: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 1.4px;
  }

  .contributors-header h2 {
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    color: #fff;
    margin-bottom: 0.8rem;
    line-height: 1.55;
    text-shadow:
      2px 0 #18083b,
      -2px 0 #18083b,
      0 2px #18083b,
      0 -2px #18083b;
  }

  .contributors-description {
    max-width: 68ch;
    color: #d9cff8;
    line-height: 1.65;
    font-size: 0.7rem;
    margin: 0;
  }

  .contributors-grid {
    display: flex;
    flex-wrap: wrap;
    grid-template-columns: repeat(5, minmax(185px, 230px));
    justify-content: center;
    column-gap: 1.5rem;
    row-gap: 1.5rem;
    margin-bottom: 1.5rem;
    padding-left: 2rem;
    padding-right: 2rem;
  }

  @media (max-width: 1220px) {
    .contributors-grid {
      grid-template-columns: repeat(5, minmax(165px, 205px));
      column-gap: 0.9rem;
      row-gap: 1.5rem;
    }
  }

  @media (max-width: 1024px) {
    .contributors-grid {
      grid-template-columns: repeat(4, minmax(160px, 205px));
      row-gap: 1.25rem;
      column-gap: 0.8rem;
    }
  }

  .contributors-legend {
    border: 2px solid #2c1a68;
    background: linear-gradient(180deg, rgba(24, 11, 64, 0.8), rgba(17, 9, 47, 0.92));
    box-shadow:
      0 0 0 2px #12072f,
      4px 4px 0 rgba(7, 3, 20, 0.7);
    padding: 0.75rem 0.9rem;
  }

  .legend-title {
    margin: 0 0 0.5rem;
    color: #f4edff;
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .legend-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.4rem;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #dcd4f8;
    font-size: 0.62rem;
    line-height: 1.45;
  }

  .legend-swatch {
    width: 14px;
    height: 14px;
    flex: 0 0 14px;
    border: 2px solid currentColor;
    box-shadow: 2px 2px 0 rgba(4, 2, 12, 0.75);
  }

  .legend-gold {
    color: #ffe438;
  }

  .legend-silver {
    color: #dbe0eb;
  }

  .legend-bronze {
    color: #bd6e31;
  }

  @media (max-width: 900px) {
    .contributors-section {
      padding: 3.7rem 1rem 4.4rem;
    }

    .contributors-grid {
      grid-template-columns: repeat(3, minmax(126px, 164px));
      column-gap: 0.62rem;
      row-gap: 0.92rem;
    }
  }

  @media (max-width: 600px) {
    .contributors-section {
      padding: 3.4rem 0.95rem 4rem;
    }

    .contributors-grid {
      grid-template-columns: minmax(260px, 320px);
      justify-content: center;
      column-gap: 0;
      row-gap: 1.15rem;
    }

    .contributors-legend {
      margin-top: 0.5rem;
    }
  }
</style>
