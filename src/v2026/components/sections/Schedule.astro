---
import scheduleData from '@/v2026/data/schedule.json'
import ScheduleCard from '@/v2026/components/sections/schedule/ScheduleCard.astro'
import {
	CATEGORY_LABELS,
	enrichScheduleData,
	groupEventsByDay,
	type EnrichedScheduleEvent,
	type EventCategory,
} from '@/v2026/utils/schedule'

const allEvents = enrichScheduleData(scheduleData)
const groupedByDay = groupEventsByDay(allEvents)

const dayEntries = Object.entries(groupedByDay).map(([dayLabel, events]) => {
	const roomSet = new Set(events.map((event) => event.laboratorio))
	const timeSet = new Set(events.map((event) => event.startTime))
	const rooms = Array.from(roomSet).sort((a, b) => a.localeCompare(b, 'es'))
	const times = Array.from(timeSet).sort((a, b) => a.localeCompare(b, 'es'))

	const matrix = events.reduce<Record<string, EnrichedScheduleEvent>>((acc, event) => {
		acc[`${event.startTime}|${event.laboratorio}`] = event
		return acc
	}, {})

	return {
		dayLabel,
		events,
		rooms,
		times,
		matrix,
	}
})

const categoryTone: Record<EventCategory, string> = {
	frontend: 'tone-frontend',
	ia: 'tone-ia',
	datos: 'tone-datos',
	seguridad: 'tone-seguridad',
	infra: 'tone-infra',
	ux: 'tone-ux',
	comunidad: 'tone-comunidad',
	general: 'tone-general',
}

const legendCategories = Object.keys(CATEGORY_LABELS) as EventCategory[]
---

<section id="agenda" class="schedule-section">
	<div class="schedule-shell">
		<header class="schedule-header">
			<p class="schedule-kicker">Agenda 2026</p>
			<h2>Explora tu ruta FLISoL</h2>
			<p class="schedule-description">
				Navega por bloques, salas y temas. Cada actividad incluye acceso rapido para agregar a Google
				Calendar o descargar archivo ICS.
			</p>

			<div class="legend" aria-label="Categorias de actividades">
				{
					legendCategories.map((category) => (
						<span class={`legend-chip ${categoryTone[category]}`}>
							<span class="dot" aria-hidden="true"></span>
							{CATEGORY_LABELS[category]}
						</span>
					))
				}
			</div>
		</header>

		<div class="day-tabs-wrapper">
			{
				dayEntries.map((entry, dayIndex) => (
					<>
						<input
							class="tab-input"
							type="radio"
							name="schedule-day"
							id={`day-${dayIndex}`}
							checked={dayIndex === 0}
						/>
						<label class="day-tab" for={`day-${dayIndex}`}>
							<span class="day-name">{entry.dayLabel}</span>
							<span class="day-count">{entry.events.length} actividades</span>
						</label>
					</>
				))
			}

			<div class="day-panels">
				{
					dayEntries.map((entry, dayIndex) => (
						<section class="day-panel" data-index={dayIndex} aria-label={`Agenda ${entry.dayLabel}`}>
							<div class="mobile-stack">
								{entry.events.map((event) => <ScheduleCard event={event} tone={categoryTone[event.category]} />)}
							</div>

							<div
								class="desktop-grid"
								role="table"
								aria-label={`Tabla de horarios ${entry.dayLabel}`}
								style={`--rooms-count:${entry.rooms.length};`}
							>
								<div class="table-head" role="rowgroup">
									<div class="head-cell hour" role="columnheader">Hora</div>
									{entry.rooms.map((room) => <div class="head-cell" role="columnheader">{room}</div>)}
								</div>

								<div class="table-body" role="rowgroup">
									{
										entry.times.map((time) => (
											<div class="table-row" role="row">
												<div class="time-cell" role="cell">
													<span>{time}</span>
												</div>

												{entry.rooms.map((room) => {
													const event = entry.matrix[`${time}|${room}`]
													return (
														<div class="event-cell" role="cell">
															{event ? (
																<ScheduleCard event={event} tone={categoryTone[event.category]} compact />
															) : (
																<div class="empty-slot" aria-hidden="true">-</div>
															)}
														</div>
													)
												})}
											</div>
										))
									}
								</div>
							</div>
						</section>
					))
				}
			</div>
		</div>
	</div>
</section>
<style>
	.schedule-section {
		position: relative;
		margin-top: -1px;
		padding: 5rem 1rem 6rem;
		background:
			linear-gradient(180deg, rgba(14, 8, 38, 0.95) 0%, rgba(22, 12, 58, 0.96) 55%, rgba(34, 14, 84, 0.98) 100%),
			radial-gradient(circle at 20% 10%, rgba(66, 150, 202, 0.28), transparent 35%),
			radial-gradient(circle at 80% 0%, rgba(233, 186, 45, 0.12), transparent 38%);
		border-top: 4px solid #4296ca;
	}

	.schedule-shell {
		width: min(1200px, 100%);
		margin: 0 auto;
	}

	.schedule-header {
		color: #f9f8ff;
		margin-bottom: 1.4rem;
	}

	.schedule-kicker {
		font-size: 0.72rem;
		color: #e9ba2d;
		margin-bottom: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 1.5px;
	}

	.schedule-header h2 {
		font-size: clamp(1.1rem, 2vw, 1.5rem);
		color: #ffffff;
		margin-bottom: 1rem;
		line-height: 1.6;
		text-shadow:
			2px 0 #18083b,
			-2px 0 #18083b,
			0 2px #18083b,
			0 -2px #18083b;
	}

	.schedule-description {
		max-width: 70ch;
		font-family: 'Montserrat', sans-serif;
		line-height: 1.45;
		color: #e5defe;
		margin-bottom: 1.2rem;
	}

	.legend {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
	}

	.legend-chip {
		border: 2px solid #111;
		background: #22155e;
		color: #f6f4ff;
		border-radius: 8px;
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.35rem 0.52rem;
		font-size: 0.58rem;
		box-shadow: 2px 2px 0 #111;
	}

	.dot {
		width: 8px;
		height: 8px;
		border-radius: 2px;
		background: currentColor;
		box-shadow: 0 0 0 1px #000;
	}

	.day-tabs-wrapper {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, max-content));
		gap: 0.6rem;
	}

	.tab-input {
		position: absolute;
		opacity: 0;
		pointer-events: none;
	}

	.day-tab {
		border: 3px solid #1a0c43;
		background: #27156e;
		color: #d6cbff;
		border-radius: 10px 10px 0 0;
		box-shadow: 3px 3px 0 #120630;
		cursor: pointer;
		min-width: 180px;
		padding: 0.7rem 0.9rem;
		display: inline-flex;
		flex-direction: column;
		gap: 0.3rem;
		transition: transform 0.15s ease;
	}

	.day-name {
		color: #fef9ff;
		font-size: 0.7rem;
	}

	.day-count {
		font-family: 'Montserrat', sans-serif;
		font-size: 0.72rem;
		color: #b7a8f8;
	}

	.day-panels {
		grid-column: 1 / -1;
		border: 4px solid #1a0c43;
		background: rgba(15, 8, 40, 0.9);
		box-shadow:
			0 0 0 2px #4296ca,
			8px 8px 0 rgba(10, 4, 27, 0.72);
		border-radius: 0 12px 12px 12px;
		min-height: 380px;
	}

	.day-panel {
		display: none;
		padding: 1rem;
	}

	#day-0:checked ~ .day-tab[for='day-0'],
	#day-1:checked ~ .day-tab[for='day-1'] {
		transform: translateY(2px);
		background: #1a0d4a;
		color: #ffffff;
		border-color: #4296ca;
		box-shadow: 2px 2px 0 #120630;
	}

	#day-0:checked ~ .day-panels .day-panel[data-index='0'],
	#day-1:checked ~ .day-panels .day-panel[data-index='1'] {
		display: block;
	}

	.mobile-stack {
		display: grid;
		gap: 0.75rem;
	}

	.desktop-grid {
		display: none;
	}

	.table-head,
	.table-row {
		display: grid;
		grid-template-columns: 110px repeat(var(--rooms-count, 1), minmax(190px, 1fr));
	}

	.head-cell,
	.time-cell,
	.event-cell {
		border-right: 1px solid rgba(139, 126, 200, 0.4);
		border-bottom: 1px solid rgba(139, 126, 200, 0.4);
	}

	.head-cell {
		position: sticky;
		top: 0;
		z-index: 3;
		background: #170a43;
		color: #ebddff;
		padding: 0.6rem;
		font-size: 0.56rem;
		line-height: 1.5;
	}

	.head-cell.hour {
		color: #9be8ff;
	}

	.time-cell {
		padding: 0.75rem 0.6rem;
		color: #9be8ff;
		font-size: 0.58rem;
		background: #130733;
	}

	.event-cell {
		background: rgba(32, 15, 83, 0.65);
		padding: 0.45rem;
	}

	.empty-slot {
		min-height: 96px;
		border: 2px dashed rgba(171, 158, 231, 0.4);
		border-radius: 8px;
		display: grid;
		place-items: center;
		color: #5f5297;
		font-size: 0.8rem;
	}

	.legend-chip.tone-frontend {
		color: #4bd5ff;
	}

	.legend-chip.tone-ia {
		color: #6ef3ab;
	}

	.legend-chip.tone-datos {
		color: #7bb8ff;
	}

	.legend-chip.tone-seguridad {
		color: #ff9850;
	}

	.legend-chip.tone-infra {
		color: #ecc15d;
	}

	.legend-chip.tone-ux {
		color: #f47dff;
	}

	.legend-chip.tone-comunidad {
		color: #f8db7d;
	}

	.legend-chip.tone-general {
		color: #bcb0e9;
	}

	@media (max-width: 900px) {
		.schedule-section {
			padding: 4.8rem 0.8rem 5.2rem;
		}

		.day-tabs-wrapper {
			grid-template-columns: 1fr 1fr;
		}

		.day-tab {
			min-width: auto;
		}
	}

	@media (min-width: 1024px) {
		.day-panel {
			padding: 0;
		}

		.mobile-stack {
			display: none;
		}

		.desktop-grid {
			display: block;
			max-height: 70vh;
			overflow: auto;
			border-radius: 0 0 10px 10px;
		}

		.table-head,
		.table-row {
			grid-template-columns: 110px repeat(var(--rooms-count, 1), minmax(220px, 1fr));
		}
	}
</style>
