---
import {
  CATEGORY_LABELS,
  toGoogleCalendarUrl,
  type EnrichedScheduleEvent,
  type EventCategory,
} from '@/v2026/utils/schedule'

interface Props {
  event: EnrichedScheduleEvent
  tone: string
  compact?: boolean
}

const { event, tone, compact = false } = Astro.props as Props
const googleUrl = toGoogleCalendarUrl(event)
const icsUrl = `/api/calendar/${event.id}.ics`
const category = event.category as EventCategory
---

<article class:list={[`schedule-card ${tone}`, compact && 'compact-card']}>
  <div class="card-top">
    <span class="time-pill">{event.startTime} - {event.endTime}</span>
    <span class="category-pill">{CATEGORY_LABELS[category]}</span>
  </div>

  <h3 class="card-title">{event.actividad}</h3>
  <p class="card-speaker">{event.speaker}</p>
  <p class="card-description">{event.description}</p>

  <div class="card-bottom">
    <span class="room-pill">{event.laboratorio}</span>

    <details class="event-details">
      <summary class="detail-trigger">Ver detalle</summary>
      <div class="detail-content">
        <p class="detail-description">{event.description}</p>
        <ul class="detail-list">
          <li><strong>Hora:</strong> {event.startTime} - {event.endTime}</li>
          <li><strong>Ponente:</strong> {event.speaker}</li>
          <li><strong>Sala:</strong> {event.laboratorio}</li>
          <li><strong>Ubicacion:</strong> {event.calendarLocation}</li>
        </ul>
        <div class="calendar-actions">
          <a href={googleUrl} target="_blank" rel="noopener noreferrer">Google Calendar</a>
          <a href={icsUrl}>Descargar ICS</a>
        </div>
      </div>
    </details>
  </div>
</article>

<style>
  .schedule-card {
    border: 3px solid #0f052f;
    background: linear-gradient(180deg, #27156b 0%, #1a0d45 100%);
    color: #f8f6ff;
    border-radius: 10px;
    padding: 0.8rem;
    box-shadow: 3px 3px 0 #0f052f;
    transition:
      transform 0.12s ease,
      box-shadow 0.12s ease,
      border-color 0.12s ease;
  }

  .schedule-card:hover {
    transform: translate(-1px, -1px);
    box-shadow: 5px 5px 0 #0f052f;
  }

  .schedule-card:active {
    transform: translate(1px, 1px);
    box-shadow: 2px 2px 0 #0f052f;
  }

  .schedule-card:focus-within {
    border-color: #e9ba2d;
    box-shadow:
      0 0 0 2px rgba(233, 186, 45, 0.4),
      3px 3px 0 #0f052f;
  }

  .card-top,
  .card-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .card-top {
    margin-bottom: 0.5rem;
  }

  .time-pill,
  .category-pill,
  .room-pill {
    border: 2px solid #000;
    border-radius: 6px;
    padding: 0.2rem 0.4rem;
    font-size: 0.52rem;
    line-height: 1.4;
    display: inline-flex;
    align-items: center;
    background: #130733;
  }

  .time-pill {
    color: #9be8ff;
  }

  .category-pill {
    color: #fdf4c9;
  }

  .card-title {
    font-size: 0.72rem;
    line-height: 1.6;
    color: #ffffff;
    margin-bottom: 0.45rem;
  }

  .card-speaker {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.85rem;
    color: #d6cdfd;
    margin-bottom: 0.4rem;
  }

  .card-description {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.8rem;
    line-height: 1.3;
    color: #d9d2ff;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 0.7rem;
  }

  .card-bottom {
    flex-wrap: wrap;
    align-items: flex-start;
  }

  .room-pill {
    color: #d6cdfd;
    max-width: 100%;
    overflow: visible;
    text-overflow: initial;
    white-space: normal;
    overflow-wrap: anywhere;
    align-self: flex-start;
  }

  .event-details {
    width: 100%;
    margin-top: 0.45rem;
    border: 2px solid #000;
    border-radius: 8px;
    background: rgba(20, 10, 58, 0.8);
  }

  .detail-trigger {
    list-style: none;
    cursor: pointer;
    width: fit-content;
    margin: 0.4rem;
    border: 1px solid #000;
    border-radius: 5px;
    background: #e9ba2d;
    color: #000;
    font-size: 0.58rem;
    padding: 0.2rem 0.42rem;
    box-shadow: 2px 2px 0 #000;
  }

  .detail-trigger::-webkit-details-marker {
    display: none;
  }

  .event-details[open] .detail-trigger {
    transform: translate(1px, 1px);
    box-shadow: 1px 1px 0 #000;
  }

  .detail-content {
    padding: 0 0.55rem 0.55rem;
  }

  .detail-description {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.78rem;
    line-height: 1.35;
    color: #f0ebff;
    margin-bottom: 0.45rem;
  }

  .detail-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.2rem;
    font-family: 'Montserrat', sans-serif;
    color: #d6cdfd;
    font-size: 0.75rem;
    line-height: 1.35;
  }

  .detail-list strong {
    color: #f3d772;
    font-weight: 600;
  }

  .calendar-actions {
    margin-top: 0.5rem;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.4rem;
  }

  .calendar-actions a {
    display: inline-flex;
    justify-content: center;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    text-decoration: none;
    color: #000;
    padding: 0.35rem 0.4rem;
    border: 2px solid #000;
    border-radius: 6px;
    background: #e9ba2d;
    box-shadow: 2px 2px 0 #000;
    text-align: center;
  }

  .calendar-actions a:hover {
    filter: brightness(1.05);
  }

  .compact-card {
    height: 100%;
  }

  .compact-card .card-title {
    font-size: 0.62rem;
    line-height: 1.5;
  }

  .compact-card .card-speaker {
    font-size: 0.75rem;
  }

  .compact-card .card-description {
    font-size: 0.72rem;
  }

  .compact-card .calendar-actions {
    grid-template-columns: 1fr;
  }

  .tone-frontend {
    border-color: #4bd5ff;
  }

  .tone-ia {
    border-color: #6ef3ab;
  }

  .tone-datos {
    border-color: #7bb8ff;
  }

  .tone-seguridad {
    border-color: #ff9850;
  }

  .tone-infra {
    border-color: #ecc15d;
  }

  .tone-ux {
    border-color: #f47dff;
  }

  .tone-comunidad {
    border-color: #f8db7d;
  }

  .tone-general {
    border-color: #bcb0e9;
  }
</style>
