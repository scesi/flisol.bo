---
import Image from 'astro/components/Image.astro'
import Background1 from '@/v2026/assets/background-hero/background_cbba_city_pixel_1.png'
import Background2 from '@/v2026/assets/background-hero/background_cbba_city_pixel_2.png'
import Background3 from '@/v2026/assets/background-hero/background_cbba_city_pixel_3.png'
import Background4 from '@/v2026/assets/background-hero/background_cbba_city_pixel_4.png'
import Background5 from '@/v2026/assets/background-hero/background_cbba_city_pixel_5.png'
import FlisolLogo from '@/v2026/assets/flisol_logo_2026.png'
import PixelGNU from '@/v2026/assets/pixel_gnu.png'
import PixelTux from '@/v2026/assets/pixel_tux.png'
import { YEAR_DATA } from '@/data/years-data'

const data = YEAR_DATA['2026']

const fechaEvento = new Date('2026-04-24T00:00:00')
const ahora = new Date()
const diferencia = fechaEvento.getTime() - ahora.getTime()

// Cálculo de días restantes
const diasRestantes = Math.max(0, Math.floor(diferencia / (1000 * 60 * 60 * 24)))
const eventoIniciado = diasRestantes === 0
---

<section class="hero">
  <div class="city">
    <Image src={Background1} alt="Background Layer 1" class="layer layer-1" />
    <Image src={Background2} alt="Background Layer 2" class="layer layer-2" />
    <Image src={Background3} alt="Background Layer 3" class="layer layer-3" />
    <Image src={Background4} alt="Background Layer 4" class="layer layer-4" />
    <Image src={Background5} alt="Background Layer 5" class="layer layer-5" />
    <div class="logo">
      <Image src={FlisolLogo} alt="Flisol Logo" class="logo-flisol" />
      <div class="info-container">
        <div class="event-date">24 y 25 de Abril, 2026</div>
        <h3>Faltan</h3>
        <div id="countdown" class="timer">--:--:--:--</div>
        <div class="action-buttons">
          <a
            href={data.registerLink}
            target="_blank"
            rel="noopener noreferrer"
            class="hero-register-button"
          >
            Inscríbete
          </a>
          <a
            href="https://itch.io/embed-upload/17283752?color=862fff"
            target="_blank"
            rel="noopener noreferrer"
            class="hero-register-button"
          >
            Jugar GNU Runner
          </a>
        </div>
      </div>
      <Image src={PixelGNU} alt="Pixel GNU" class="pixel-gnu" />
      <Image src={PixelTux} alt="Pixel Tux" class="pixel-tux" />
    </div>
  </div>
  <div class="floor">
    <div class="grid-container">
      <div class="grid-lines"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    margin-top: 4.5rem;
    height: calc(100vh - 4.5rem);
    display: flex;
    flex-direction: column;
  }

  .city {
    position: relative;
    width: 100%;
    flex: 1;
    background: linear-gradient(to bottom, #210a50, #4296ca);
    overflow: hidden;
  }

  .floor {
    position: relative;
    bottom: 0;
    width: 100%;
    height: 21%;
    background: #210a50;
    overflow: hidden;
    perspective: 400px;
    z-index: 20;
  }

  .logo {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    z-index: 10;
  }

  .floor::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 80%;
    pointer-events: none;
    z-index: 10;
    background-image: radial-gradient(rgba(0, 0, 0, 0.4) 1px, transparent 0);
    background-size: 3px 3px;
  }

  .grid-container {
    position: absolute;
    top: 0;
    left: -50%;
    width: 200%;
    height: 100%;
    transform: rotateX(45deg);
    transform-origin: top;
  }

  .grid-lines {
    width: 100%;
    height: 1000%;
    margin-top: -100px;
    background-image:
      linear-gradient(to right, rgba(66, 150, 202, 0.3) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(66, 150, 202, 0.3) 1px, transparent 1px);
    background-size: 40px 40px;
    filter: drop-shadow(0 0 2px rgb(107, 162, 196)) drop-shadow(0 0 5px rgba(196, 214, 224, 0.5));
    animation: move-grid 2s linear infinite;
  }

  @keyframes move-grid {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(40px);
    }
  }

  .layer {
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    animation: bounce-in 1.5s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }

  @keyframes bounce-in {
    0% {
      transform: translateY(100%);
    }
    60% {
      transform: translateY(0%);
    }
    80% {
      transform: translateY(1%);
    }
    100% {
      transform: translateY(0);
    }
  }

  .floor {
    height: 21%;
  }

  .layer-1 {
    z-index: 5;
    filter: drop-shadow(0 0 5px black);
    animation-delay: 0.1s;
    filter: blur(1px);
  }

  .layer-2 {
    z-index: 4;
    filter: drop-shadow(0 0 5px rgba(0, 0, 0, 0.322));
    animation-delay: 0.2s;
    filter: blur(2px);
  }

  .layer-3 {
    z-index: 3;
    filter: drop-shadow(0 0 5px rgba(0, 0, 0, 0.212));
    animation-delay: 0.3s;
    filter: blur(4px);
    opacity: 0.5;
  }

  .layer-4 {
    z-index: 2;
    margin-bottom: -50px;
    animation-delay: 0.4s;
    filter: drop-shadow(0 0 5px rgba(0, 0, 0, 0.5));
    filter: blur(1px);
  }

  .layer-5 {
    margin-bottom: -50px;
    z-index: 0;
    animation-delay: 0.5s;
    filter: blur(3px);
  }

  .logo-flisol {
    z-index: 6;
    width: 30%;
    height: auto;
  }

  .pixel-gnu {
    position: absolute;
    bottom: 0;
    left: 0;
    z-index: 7;
    width: 15%;
    height: auto;
    transform: scaleX(-1);
    filter: drop-shadow(0 0 5px rgba(255, 255, 255, 0.8));
  }

  .pixel-tux {
    position: absolute;
    bottom: 0;
    right: 0;
    z-index: 8;
    width: 15%;
    height: auto;
    animation-delay: 0.8s;
    filter: drop-shadow(0 0 5px rgba(255, 255, 255, 0.8));
  }

  .info-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    color: white;
    margin-top: 20px;
    text-shadow: 0 0 10px rgba(66, 150, 202, 0.8);
    font-family: 'Montserrat', sans-serif;
  }

  .event-date {
    font-size: 1.5rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .timer {
    font-size: 2.5rem;
    font-weight: bold;
    background: rgba(33, 10, 80, 0.6);
    padding: 10px 20px;
    border: 2px solid #4296ca;
    border-radius: 5px;
  }

  .action-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    align-items: center;
    margin-top: 15px;
  }

  .hero-register-button {
    display: inline-block;
    background-color: #e9ba2d;
    color: black;
    padding: 0.5rem 1rem;
    border-radius: 5px;
    border: 3px solid black;
    letter-spacing: 1px;
    box-shadow: 4px 4px 0px black;
    text-decoration: none;
    font-weight: bold;
    font-family: 'PressStart2P', sans-serif;
    font-size: 0.9rem;
    text-shadow: none;
    z-index: 20;
    transition: transform 0.1s;
  }

  .hero-register-button:hover {
    background-color: #6d28d9;
    color: white;
    transform: translateY(-2px);
    box-shadow: 6px 6px 0px black;
  }

  .hero-register-button:active {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0px black;
  }

  @media screen and (max-width: 768px) {
    .hero {
      margin-top: 3rem;
      height: calc(100vh - 3rem);
    }

    .city {
      height: 77%;
    }

    .floor {
      height: 23%;
    }

    .layer-4 {
      object-position: 30% 160%;
      margin-bottom: -80px;
      z-index: 2;
      filter: drop-shadow(0 0 5px rgba(0, 0, 0, 0.5));
    }

    .logo-flisol {
      margin-top: 6rem;
      width: 70%;
    }

    .pixel-gnu {
      width: 30%;
    }

    .pixel-tux {
      width: 25%;
    }

    .event-date {
      font-size: 1rem;
    }

    .timer {
      font-size: 1rem;
    }

    .action-buttons {
      flex-direction: column;
      gap: 0.8rem;
      width: 100%;
    }

    .hero-register-button {
      font-size: 0.75rem;
      width: 100%;
      text-align: center;
      box-sizing: border-box;
    }
  }
</style>
<script>
  const targetDate = new Date('2026-04-24T08:30:00').getTime()

  function updateCountdown() {
    const now = new Date().getTime()
    const distance = targetDate - now

    const days = Math.floor(distance / (1000 * 60 * 60 * 24))
    const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60))
    const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60))
    const seconds = Math.floor((distance % (1000 * 60)) / 1000)

    const timerElement = document.getElementById('countdown')
    if (timerElement) {
      timerElement.innerHTML = `${days}d ${hours}h ${minutes}m ${seconds}s`
    }
  }

  setInterval(updateCountdown, 1000)
  updateCountdown()
</script>
