---
import Schedule from './components/schedule.astro'
import { AgendaIsland } from './components/agenda-island/AgendaIsland.tsx'
import data from '@/data/schedule.json'

import RunTux from '@/assets/icons/svg/run-tux.svg'
import BrokenPaper from '@/assets/icons/svg/broken-paper.svg'
import TuxComic from '@/assets/icons/svg/tux-comic.svg'
import FocusComic from '@/assets/icons/svg/focus-comic.svg'
import GnuComic from '@/assets/icons/svg/gnu-comic.png'
import Flag from '@/assets/icons/svg/flag-tux.png'

import { Image } from 'astro:assets'

const imageFiles = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/2025/*/*.{JPG,jpg,png,jpeg,webp}',
  {
    eager: true,
  }
)

const images = Object.values(imageFiles).map((img) => img.default)
---

<div class="content-container">
  <div class="title content-box">
    <span>FLISOL 2025</span>
  </div>

  <div class="about-event content-box image-container" id="about">
    <RunTux />
  </div>

  <div class="about-event-dark content-box dark-box">
    <div>
      <h3 class="dark-title">Sobre el evento</h3>
      <p class="dark-description">
        El FLISoL (Festival Latinoamericano de Instalación de Software Libre) es un evento anual que
        busca difundir y <span class="highlighted">promover el Software Libre en Latinoamérica</span
        >. Es el evento de difusión de Software Libre más grande en el mundo hispanohablante, con
        una presencia simultánea en diversos países. Se realiza anualmente el cuarto sábado de
        abril.
      </p>
    </div>
  </div>

  <div class="subtitle content-box" id="agenda">
    <div>
      <h4 class="subtitle-text">AGENDA</h4>
      <BrokenPaper />
    </div>
  </div>

  <AgendaIsland client:load agendaData={data} tuxIcon={TuxComic.src} gnuIcon={GnuComic.src} />

  <div class="capture-the-flag content-box">
    <div class="matrix-screen">
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
    </div>

    <img src={Flag.src} alt="Logo de Tux estilo comic con una bandera" class="gnu-logo" />
    <div class="capture-the-flag__content">
      <p class="capture-the-flag__title">CAPTURE THE FLAG</p>
      <p class="capture-the-flag__button">RESULTADOS!</p>
    </div>
  </div>

  <div class="gallery-title content-box">
    <h4>Galería</h4>
  </div>

  <div class="gallery content-box" style={`--num-images: ${images.length}`}>
    <div class="slider-wrapper">
      {
        [...images, ...images].map((img) => (
          <div class="slide">
            <Image src={img} alt="Momento del FLISoL 2025" width={400} height={450} />
          </div>
        ))
      }
    </div>
  </div>
</div>

<style lang="scss">
  .content-box {
    border: 5px solid black;
  }

  .content-container {
    margin: 2rem;
    display: grid;
    grid-template-columns: repeat(6, minmax(auto, 1fr));
    grid-template-rows: repeat(10, auto);
    grid-column-gap: 0.5rem;
    grid-row-gap: 0.5rem;

    .title {
      grid-column: 1 / 7;
      grid-row: 1 / 2;
      display: flex;
      align-items: center;
      justify-content: center;
      background-color: #dd4547;
      padding: 2rem;

      span {
        color: #efe524;
        -webkit-text-stroke: 4px black;
        font-size: 4.375rem;
        text-shadow: 4px 4px black;
        text-align: center;
        margin-bottom: -1.25rem;
      }
    }

    .day-label {
      position: absolute;
      bottom: 0.25rem;
      font-size: 4.375rem;
      right: 2rem;
    }

    .dark-box {
      background-color: #1e1e1e;
      color: white;
      padding: 2rem;
    }

    .dark-title {
      color: #efe524;
      font-size: 2rem;
      font-weight: 300;
      text-align: start;
    }

    .highlighted {
      color: #efe524;
      font-weight: bold;
    }

    .dark-description {
      font-family: Arial, Helvetica, sans-serif;
      font-weight: 100;
      margin-top: 1rem;
      font-size: 1.8rem;
    }

    .about-event {
      grid-column: 1 / 3;
      grid-row: 2 / 3;
      height: 423px;
      position: relative;
    }

    .about-event-dark {
      grid-column: 3 / 7;
      grid-row: 2 / 3;
      height: 423px;
      position: relative;
    }

    .subtitle {
      position: relative;
      grid-column: 1 / 7;
      grid-row: 3 / 4;
      height: 200px;
      background-color: #ff6d6d;
      display: flex;
      justify-content: center;
      align-items: center;
      z-index: 2;
    }

    .subtitle-text {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      color: #efe524;
      -webkit-text-stroke: 2px #dd4547;
      font-size: 3rem;
      text-shadow: 4px 4px black;
    }

    .capture-the-flag {
      position: relative;
      overflow: hidden;
      grid-column: 1 / 7;
      grid-row: 7 / 8;
      height: 423px;
      background-color: #1e1e1e;
      display: flex;
      flex-direction: row;
      justify-content: center;
      align-items: center;
      gap: 5rem;
      img,
      .capture-the-flag__content {
        position: relative;
        z-index: 1;
      }

      img {
        width: 150px;
        height: auto;
        margin-bottom: 1rem;
      }

      .matrix-screen {
        position: absolute;
        inset: 0;
        display: flex;
        justify-content: space-around;
        opacity: 0.4;
        pointer-events: none;
      }

      .column {
        position: relative;
        width: 20px;
        height: 100%;
        color: rgba(111, 228, 69, 0.15);
        font-family: monospace;
        font-size: 18px;
        text-align: center;
        word-break: break-all;
        line-height: 0.9;

        &::before {
          content: '101011010101101100101011010101101100101011010101101100101011010101101100';
        }

        &::after {
          content: '10101';
          position: absolute;
          top: -20%;
          left: 0;
          width: 100%;
          color: #6fe445;
          text-shadow:
            0 0 10px #6fe445,
            0 0 20px #6fe445;
          animation: drop linear infinite;
        }
      }

      @for $i from 1 through 100 {
        .column:nth-child(#{$i}) {
          &::after {
            animation-duration: #{random(3) + 2}s;
            animation-delay: #{random(5)}s;
          }
        }
      }

      img,
      &__content {
        position: relative;
        z-index: 2;
      }

      @keyframes drop {
        0% {
          top: -20%;
          opacity: 0;
        }
        10% {
          opacity: 1;
        }
        90% {
          opacity: 1;
        }
        100% {
          top: 100%;
          opacity: 0;
        }
      }

      &__content {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
      }

      &__button {
        margin-top: 2rem;
        padding: 0.5rem 2.5rem;
        background-color: #6fe445;
        border: 1px solid black;
        box-shadow: 3px 3px white;
      }

      &__title {
        color: #efe524;
        -webkit-text-stroke: 2px black;
        font-size: 3.375rem;
        text-shadow: 4px 4px #dd4547;
        text-align: center;
        margin-bottom: -1.25rem;
      }
    }

    .gallery-title {
      display: flex;
      justify-content: center;
      align-items: center;
      grid-column: 1 / 7;
      grid-row: 8 / 8;
      height: 60px;
      color: #efe524;
      -webkit-text-stroke: 0.3px #dd4547;
      font-size: 2rem;
      text-shadow: 4px 4px black;
    }

    .gallery {
      grid-column: 1 / 7;
      grid-row: 9 / 10;
      height: 450px;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      position: relative;
      background: #000;

      .slider-wrapper {
        display: flex;
        width: calc(400px * var(--num-images) * 2);
        animation: scroll 100s linear infinite;
        height: 100%;
        &:hover {
          animation-play-state: paused;
          animation-duration: infinite;
        }
      }

      .slide {
        flex-shrink: 0;
        width: 400px;
        height: 100%;
        border-right: 5px solid black;

        img {
          width: 100%;
          height: 100%;
          object-fit: cover;
        }
      }
    }

    @keyframes scroll {
      0% {
        transform: translateX(0);
      }
      100% {
        transform: translateX(calc(-400px * var(--num-images)));
      }
    }

    .image-container {
      display: flex;
      justify-content: center;
      align-items: center;
    }
  }
  @media only screen and (max-width: 800px) {
    .content-container {
      margin: 0.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;

      .about-event,
      .about-event-dark {
        width: 100%;
        height: auto;
        min-height: fit-content;
        padding: 1.5rem;
      }

      .dark-description {
        font-size: 1.2rem;
        line-height: 1.4;
      }

      .title {
        padding: 1.5rem 1rem;
        span {
          font-size: 2.5rem;
          -webkit-text-stroke: 2px black;
        }
      }

      .subtitle {
        height: 60px;
        display: flex;
        justify-content: center;
        align-items: center;
        .subtitle-text {
          font-size: 2rem;
        }
        svg {
          display: none;
        }
      }

      .capture-the-flag {
        flex-direction: column;
        height: auto;
        padding: 3rem 1rem;
        gap: 2rem;

        &__title {
          font-size: 2.2rem;
        }

        img {
          width: 120px;
        }
      }

      .gallery-title {
        grid-column: 1 / 7;
        grid-row: 8 / 8;
        height: 60px;
      }
      .gallery {
        height: 300px;
        width: 100%;

        .slide {
          width: 250px;
        }
      }

      @keyframes scroll {
        100% {
          transform: translateX(calc(-250px * var(--num-images)));
        }
      }
    }
  }
</style>
