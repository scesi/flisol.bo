---
import type { Contributor, Network } from '@/types/contributor'
const { contributor } = Astro.props

const github = contributor.networks.find((n: Network) => n.network_name === 'GitHub')
const avatarUrl = github
  ? `https://github.com/${github.username}.png`
  : 'src/assets/icons/default_avatar.png'
---

<div class="contributor-card">
  <div class="avatar-wrapper">
    <img src={avatarUrl} alt={`Avatar de ${contributor.name}`} class="avatar" />
    <div class="speech-bubble">
      ¡{contributor.name}!
    </div>
  </div>
  <div class="info-content">
    <h3 class="mobile-name">{contributor.name}</h3>
    <div class="role">{contributor.role}</div>
    <div class="networks">
      {
        contributor.networks.map((net: Network) => (
          <a
            href={net.url}
            target="_blank"
            rel="noopener"
            class={`network-icon ${net.network_name.toLowerCase()}`}
          >
            {net.network_name}
          </a>
        ))
      }
    </div>
  </div>
</div>

<style>
  .contributor-card {
    background: #edff86;
    border: 4px solid #222;
    border-radius: 18px;
    padding: 1.5rem 1rem 1rem 1rem;
    box-shadow: 6px 6px 0 #222;
    width: 250px;
    margin: 1.5rem auto;
    font-family: 'Comic Neue', 'Bangers', cursive, sans-serif;
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 280px;
  }

  .avatar-wrapper {
    position: relative;
    text-align: center;
    flex-shrink: 0;
    width: 100%;
    height: 90px;
    margin-bottom: 15px;
  }

  .avatar {
    width: 90px;
    height: 90px;
    object-fit: cover;
    border-radius: 50%;
    border: 3px solid #222;
    background: #eee;
    display: inline-block;
  }

  .speech-bubble {
    position: absolute;
    left: 50%;
    top: -10px;
    background: #fff;
    border: 3px solid #222;
    border-radius: 18px;
    padding: 0.3em 1em;
    font-size: 1.1em;
    color: #222;
    box-shadow: 3px 3px 0 #222;
    white-space: nowrap;
    z-index: 2;
  }

  .info-content {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .mobile-name {
    display: none;
    margin: 0;
    font-size: 1.4em;
    font-weight: 900;
    color: #222;
    text-transform: uppercase;
  }

  .role {
    margin-top: 0.8em;
    font-size: 1.1em;
    font-weight: bold;
    color: black;
    text-align: center;
    flex-grow: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    text-shadow:
      1px 1px 0 #fff,
      2px 2px 0 #dd4547;
  }

  .networks {
    margin-top: auto;
    padding-top: 1em;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.5em;
  }
  .network-icon {
    display: inline-block;
    padding: 0.2em 0.5em;
    border-radius: 10px;
    border: 2px solid #222;
    background: #f1c40f;
    color: #222;
    font-weight: bold;
    text-decoration: none;
    font-size: 0.75em;
    transition: transform 0.2s;
  }
  .network-icon.github {
    background: #24292f;
    color: #fff;
  }
  .network-icon.linkedin {
    background: #0077b5;
    color: #fff;
  }
  .network-icon.instagram {
    background: #e1306c;
    color: #fff;
  }
  .network-icon.behance {
    background: #1769ff;
    color: #fff;
  }
  .network-icon.dribbble {
    background: #ea4c89;
    color: #fff;
  }
  .network-icon.tiktok {
    background: #000;
    color: #fff;
  }
  .network-icon.youtube {
    background: #ff0000;
    color: #fff;
  }

  @media (max-width: 600px) {
    .contributor-card {
      flex-direction: row;
      width: 90%;
      max-width: 400px;
      min-height: auto;
      padding: 1rem;
      align-items: center;
      gap: 1.5rem;
    }

    .avatar-wrapper {
      width: 80px;
      height: 80px;
      margin-bottom: 0;
      flex-shrink: 0;
    }

    .avatar {
      width: 80px;
      height: 80px;
    }

    .speech-bubble {
      display: none;
    }

    .mobile-name {
      display: block;
      font-family: 'Luckiest_Guy', sans-serif;
      line-height: 1;
      font-size: 1em;
      font-weight: bold;
    }

    .info-content {
      text-align: left;
      align-items: flex-start;
    }

    .role {
      text-align: left;
      justify-content: flex-start;
      font-size: 1em;
    }

    .networks {
      justify-content: flex-start;
      padding-top: 0.5rem;
    }
  }
</style>
